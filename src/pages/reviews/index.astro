---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const reviews = (await getCollection('reviews'))
	.filter((r) => !r.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const cities = ['All', ...new Set(reviews.map((r) => r.data.city))];
const cuisines = ['All', ...new Set(reviews.map((r) => r.data.cuisine))];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Reviews · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.filters {
				margin-bottom: 2rem;
			}
			.filter-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-bottom: 0.6em;
				align-items: center;
			}
			.filter-label {
				font-size: 0.75em;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
				min-width: 60px;
			}
			.filter-btn {
				border: 1.5px solid rgb(var(--gray-light));
				background: var(--paper);
				color: rgb(var(--gray));
				border-radius: 999px;
				padding: 0.3em 0.9em;
				font-size: 0.82em;
				cursor: pointer;
				transition: all 0.15s;
				font-family: var(--font-body, system-ui, sans-serif);
			}
			.filter-btn:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.filter-btn.active {
				background: var(--accent);
				border-color: var(--accent);
				color: white;
			}
			.review-count {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-bottom: 1.5rem;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				width: 100%;
				aspect-ratio: 2/1;
				object-fit: cover;
			}
			ul li a {
				display: block;
			}
			ul li.hidden {
				display: none;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.meta {
				margin: 0.25em 0 0;
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			ul li a:hover h3,
			ul li a:hover .meta {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			.no-results {
				display: none;
				text-align: center;
				padding: 3em 1em;
				color: rgb(var(--gray));
				font-style: italic;
			}
			@media (max-width: 720px) {
				ul { gap: 0.5em; }
				ul li { width: 100%; text-align: center; }
				ul li:first-child { margin-bottom: 0; }
				ul li:first-child .title { font-size: 1.563em; }
				.filter-label { display: none; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1 style="margin-bottom: 1.5rem; font-size: 2rem;">Restaurant Reviews</h1>

				<div class="filters">
					<div class="filter-row">
						<span class="filter-label">City</span>
						{cities.map((city) => (
							<button
								class={`filter-btn city-btn${city === 'All' ? ' active' : ''}`}
								data-city={city}
							>
								{city}
							</button>
						))}
					</div>
					<div class="filter-row">
						<span class="filter-label">Cuisine</span>
						{cuisines.map((cuisine) => (
							<button
								class={`filter-btn cuisine-btn${cuisine === 'All' ? ' active' : ''}`}
								data-cuisine={cuisine}
							>
								{cuisine}
							</button>
						))}
					</div>
				</div>

				<p class="review-count" id="count">{reviews.length} reviews</p>

				<ul id="review-grid">
					{
						reviews.map((review) => (
							<li data-city={review.data.city} data-cuisine={review.data.cuisine}>
								<a href={`/reviews/${review.id}/`}>
									<img src={review.data.photo} alt={review.data.photoAlt ?? review.data.venue} />
									<h3 class="title">{review.data.title}</h3>
									<p class="meta">
										{review.data.cuisine} · {review.data.neighborhood ? `${review.data.neighborhood}, ` : ''}{review.data.city}
										{' · '}
										<FormattedDate date={review.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
				<p class="no-results" id="no-results">No reviews found for this filter.</p>
			</section>
		</main>
		<Footer />

		<script>
			const cityBtns = document.querySelectorAll<HTMLButtonElement>('.city-btn');
			const cuisineBtns = document.querySelectorAll<HTMLButtonElement>('.cuisine-btn');
			const items = document.querySelectorAll<HTMLLIElement>('#review-grid li');
			const countEl = document.getElementById('count');
			const noResults = document.getElementById('no-results');

			let activeCity = 'All';
			let activeCuisine = 'All';

			function applyFilters() {
				let visible = 0;
				items.forEach((item) => {
					const cityMatch = activeCity === 'All' || item.dataset.city === activeCity;
					const cuisineMatch = activeCuisine === 'All' || item.dataset.cuisine === activeCuisine;
					if (cityMatch && cuisineMatch) {
						item.classList.remove('hidden');
						visible++;
					} else {
						item.classList.add('hidden');
					}
				});
				if (countEl) countEl.textContent = `${visible} review${visible !== 1 ? 's' : ''}`;
				if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
			}

			cityBtns.forEach((btn) => {
				btn.addEventListener('click', () => {
					cityBtns.forEach((b) => b.classList.remove('active'));
					btn.classList.add('active');
					activeCity = btn.dataset.city ?? 'All';
					applyFilters();
				});
			});

			cuisineBtns.forEach((btn) => {
				btn.addEventListener('click', () => {
					cuisineBtns.forEach((b) => b.classList.remove('active'));
					btn.classList.add('active');
					activeCuisine = btn.dataset.cuisine ?? 'All';
					applyFilters();
				});
			});
		</script>
	</body>
</html>
