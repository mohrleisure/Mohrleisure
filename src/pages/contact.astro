---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Contact | ${SITE_TITLE}`}
			description="Get in touch with Skyler & Kristen Mohr — restaurant recommendations, collaborations, or just to say hello."
		/>
		<style>
			.contact-hero {
				padding: 4em 1em 3em;
				text-align: center;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.contact-hero h1 {
				font-size: 3rem;
				margin: 0 0 0.5em;
			}
			.contact-hero p {
				color: rgb(var(--gray));
				font-style: italic;
				max-width: 480px;
				margin: 0 auto;
			}
			.contact-content {
				max-width: 600px;
				margin: 0 auto;
				padding: 3em 1em 4em;
			}
			.contact-card {
				display: flex;
				align-items: flex-start;
				gap: 1.2em;
				padding: 1.5em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				margin-bottom: 1.2em;
				text-decoration: none;
				color: inherit;
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			.contact-card:hover {
				border-color: var(--accent);
				box-shadow: var(--box-shadow);
			}
			.contact-icon {
				width: 44px;
				height: 44px;
				background: var(--accent);
				border-radius: 10px;
				display: flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
				color: white;
			}
			.contact-card h2 {
				font-size: 1em;
				margin: 0 0 0.2em;
				font-family: var(--font-body, system-ui, sans-serif);
				font-weight: 600;
			}
			.contact-card p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.contact-card .link {
				color: var(--accent);
				font-size: 0.9em;
				margin-top: 0.3em;
				display: block;
			}
			.divider {
				text-align: center;
				color: rgb(var(--gray));
				font-size: 0.85em;
				margin: 2em 0;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="contact-hero">
			<h1>Get in touch.</h1>
			<p>A recommendation, a collaboration, or just a great tip — we're listening.</p>
		</div>
		<main>
			<div class="contact-content">

				<a class="contact-card" href="mailto:mohrleisure@gmail.com">
					<div class="contact-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<rect x="2" y="4" width="20" height="16" rx="2"/>
							<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
						</svg>
					</div>
					<div>
						<h2>Email us</h2>
						<p>Best for restaurant tips, collaborations, and general questions.</p>
						<span class="link">mohrleisure@gmail.com</span>
					</div>
				</a>

				<a class="contact-card" href="https://www.instagram.com/mohrleisure/" target="_blank">
					<div class="contact-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
							<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
						</svg>
					</div>
					<div>
						<h2>Instagram</h2>
						<p>Follow along for food photos, new reviews, and where we're eating next.</p>
						<span class="link">@mohrleisure</span>
					</div>
				</a>

				<a class="contact-card" href="https://www.tiktok.com/@mohrleisure" target="_blank">
					<div class="contact-icon" style="background: #000;">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
							<path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
						</svg>
					</div>
					<div>
						<h2>TikTok</h2>
						<p>Short-form takes on where we're eating and what's worth ordering.</p>
						<span class="link">@mohrleisure</span>
					</div>
				</a>


</div>
		</main>
		<Footer />
	</body>
</html>
