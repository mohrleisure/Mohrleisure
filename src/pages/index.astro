---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const recent = (await getCollection('reviews'))
	.filter((r) => !r.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 3em 1em 2em;
			}
			.hero h1 {
				font-size: 3rem;
				margin: 0 0 0.5em;
			}
			.hero p {
				color: rgb(var(--gray));
				max-width: 540px;
				margin: 0 auto 1.5em;
			}
			.hero a.cta {
				display: inline-block;
				background: rgb(var(--accent));
				color: white;
				padding: 0.6em 1.4em;
				border-radius: 999px;
				text-decoration: none;
				font-weight: 600;
			}
			.recent {
				max-width: 960px;
				margin: 0 auto;
				padding: 0 1em 3em;
			}
			.recent h2 {
				margin-bottom: 1.5em;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(33.33% - 1.35rem);
			}
			ul li img {
				width: 100%;
				aspect-ratio: 3/2;
				object-fit: cover;
				border-radius: 12px;
				margin-bottom: 0.5rem;
			}
			ul li a {
				display: block;
				text-decoration: none;
				transition: 0.2s ease;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
			}
			.meta {
				margin: 0.25em 0 0;
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			ul li a:hover .title,
			ul li a:hover .meta {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul li {
					width: 100%;
				}
				.hero h1 {
					font-size: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>Mohr Leisure</h1>
				<p>{SITE_DESCRIPTION}</p>
				<a class="cta" href="/reviews/">Browse all reviews</a>
			</div>
			<div class="recent">
				<h2>Recent reviews</h2>
				<ul>
					{
						recent.map((review) => (
							<li>
								<a href={`/reviews/${review.id}/`}>
									<img src={review.data.photo} alt={review.data.photoAlt ?? review.data.venue} />
									<h4 class="title">{review.data.title}</h4>
									<p class="meta">
										{review.data.cuisine} · {review.data.city}
										{' · '}
										<FormattedDate date={review.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</main>
		<Footer />
	</body>
</html>
