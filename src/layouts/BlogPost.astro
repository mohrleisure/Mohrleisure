---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'reviews'>['data'] & {
	related?: CollectionEntry<'reviews'>[];
};

const pageUrl = Astro.url.href;

const { title, venue, city, neighborhood, cuisine, pubDate, photo, photoAlt, gallery = [], standoutDishes = [], related = [], priceRange, address, reservationUrl } = Astro.props;

const description = standoutDishes.length > 0
	? `${cuisine} in ${neighborhood ? neighborhood + ', ' : ''}${city} — ${standoutDishes.slice(0, 2).join(', ')} and more. A review by Skyler & Kristen Mohr.`
	: `${cuisine} restaurant in ${neighborhood ? neighborhood + ', ' : ''}${city}. A review by Skyler & Kristen Mohr.`;

const pageTitle = `${title} | Mohr Leisure`;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Review',
	author: {
		'@type': 'Person',
		name: 'Skyler & Kristen Mohr',
		url: 'https://mohrleisure.com/about/',
	},
	datePublished: pubDate.toISOString().split('T')[0],
	itemReviewed: {
		'@type': 'Restaurant',
		name: venue,
		servesCuisine: cuisine,
		address: {
			'@type': 'PostalAddress',
			addressLocality: city,
			...(neighborhood ? { addressRegion: neighborhood } : {}),
		},
	},
	publisher: {
		'@type': 'Organization',
		name: 'Mohr Leisure',
		url: 'https://mohrleisure.com',
	},
};
---

<html lang="en">
	<head>
		<BaseHead
			title={pageTitle}
			description={description}
			image={photo}
			type="article"
			pubDate={pubDate}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				width: 100%;
				max-height: 500px;
				object-fit: cover;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.meta {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.dishes {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
				justify-content: center;
				margin-top: 0.75em;
			}
			.dish-tag {
				background: var(--accent);
				color: white;
				border-radius: 999px;
				padding: 0.2em 0.75em;
				font-size: 0.8em;
			}
			.breadcrumb {
				font-size: 0.8em;
				color: rgb(var(--gray));
				padding: 0.75em 1em;
				max-width: 720px;
				margin: 0 auto;
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.related {
				max-width: 720px;
				margin: 3em auto 0;
				padding: 2em 1em;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.related h2 {
				font-size: 1.2em;
				margin: 0 0 1.2em;
			}
			.related-grid {
				display: flex;
				gap: 1.5em;
				flex-wrap: wrap;
			}
			.related-card {
				flex: 1;
				min-width: 160px;
				text-decoration: none;
				color: inherit;
			}
			.related-card img {
				width: 100%;
				aspect-ratio: 3/2;
				object-fit: cover;
				border-radius: 8px;
				margin-bottom: 0.4em;
				transition: box-shadow 0.2s;
			}
			.related-card:hover img {
				box-shadow: var(--box-shadow);
			}
			.related-card h3 {
				font-size: 0.95em;
				margin: 0 0 0.2em;
				line-height: 1.3;
			}
			.related-card p {
				font-size: 0.78em;
				color: rgb(var(--gray));
				margin: 0;
			}
			.related-card:hover h3 {
				color: var(--accent);
			}
			.info-bar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6em 1.5em;
				padding: 1em 0;
				margin: 0.5em 0 1.5em;
				border-top: 1px solid rgb(var(--gray-light));
				border-bottom: 1px solid rgb(var(--gray-light));
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.info-item {
				display: flex;
				align-items: center;
				gap: 0.35em;
			}
			.reservation-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				background: var(--accent);
				color: white;
				padding: 0.25em 0.8em;
				border-radius: 999px;
				text-decoration: none;
				font-size: 0.8em;
				font-weight: 600;
				transition: opacity 0.15s;
			}
			.reservation-btn:hover { opacity: 0.85; }
			.share-bar {
				display: flex;
				align-items: center;
				gap: 0.75em;
				margin: 2.5em 0 0;
				padding-top: 1.5em;
				border-top: 1px solid rgb(var(--gray-light));
				font-size: 0.82em;
				color: rgb(var(--gray));
			}
			.share-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.35em;
				padding: 0.35em 0.85em;
				border: 1.5px solid rgb(var(--gray-light));
				border-radius: 999px;
				text-decoration: none;
				color: rgb(var(--gray-dark));
				font-size: 0.85em;
				transition: border-color 0.15s, color 0.15s;
				background: var(--paper);
				cursor: pointer;
				font-family: var(--font-body, system-ui, sans-serif);
			}
			.share-btn:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.gallery {
				margin: 2.5em 0;
				padding-top: 1.5em;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.gallery h2 {
				font-size: 1.1em;
				margin: 0 0 1em;
				color: rgb(var(--gray));
				font-family: var(--font-body, system-ui, sans-serif);
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.gallery-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0.5em;
			}
			@media (max-width: 600px) {
				.gallery-grid { grid-template-columns: repeat(2, 1fr); }
			}
			.gallery-grid button {
				all: unset;
				cursor: zoom-in;
				display: block;
				aspect-ratio: 1;
				overflow: hidden;
				border-radius: 6px;
			}
			.gallery-grid button img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.2s;
				border-radius: 6px;
			}
			.gallery-grid button:hover img { transform: scale(1.03); }
			.lightbox {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0,0,0,0.92);
				z-index: 1000;
				align-items: center;
				justify-content: center;
				cursor: zoom-out;
			}
			.lightbox.open { display: flex; }
			.lightbox img {
				max-width: 92vw;
				max-height: 92vh;
				object-fit: contain;
				border-radius: 4px;
				box-shadow: 0 4px 40px rgba(0,0,0,0.6);
			}
			.lightbox-close {
				position: absolute;
				top: 1.2em;
				right: 1.4em;
				color: white;
				font-size: 2rem;
				line-height: 1;
				cursor: pointer;
				background: none;
				border: none;
				opacity: 0.8;
			}
			.lightbox-close:hover { opacity: 1; }
		</style>
	</head>

	<body>
		<Header />
		<nav class="breadcrumb" aria-label="Breadcrumb">
			<a href="/reviews/">Reviews</a>
			{' › '}
			<a href={`/reviews/?city=${encodeURIComponent(city)}`}>{city}</a>
			{' › '}
			<span>{venue}</span>
		</nav>
		<main>
			<article>
				<div class="hero-image">
					{photo && <img src={photo} alt={photoAlt ?? venue} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="meta">
							<FormattedDate date={pubDate} />
							{' · '}
							{cuisine}
							{' · '}
							{neighborhood ? `${neighborhood}, ` : ''}{city}
						</div>
						<h1>{title}</h1>
						{standoutDishes.length > 0 && (
							<div class="dishes">
								{standoutDishes.map((dish) => (
									<span class="dish-tag">{dish}</span>
								))}
							</div>
						)}
						<hr />
					</div>

					{(priceRange || address || reservationUrl) && (
						<div class="info-bar">
							{priceRange && (
								<span class="info-item">
									<span>💰</span> {priceRange}
								</span>
							)}
							{address && (
								<span class="info-item">
									<span>📍</span> {address}
								</span>
							)}
							{reservationUrl && (
								<a class="reservation-btn" href={reservationUrl} target="_blank" rel="noopener">
									Reserve a table ↗
								</a>
							)}
						</div>
					)}

					<slot />

					{gallery.length > 0 && (
						<div class="gallery">
							<h2>Photos</h2>
							<div class="gallery-grid">
								{gallery.map((src, i) => (
									<button class="gallery-thumb" data-src={src} aria-label={`Photo ${i + 1}`}>
										<img src={src} alt={`${venue} photo ${i + 1}`} loading="lazy" />
									</button>
								))}
							</div>
						</div>
					)}

					<div class="share-bar">
						<span>Share:</span>
						<button class="share-btn" id="copy-link">
							<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
							Copy link
						</button>
						<a class="share-btn" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title + ' — ' + venue + ', ' + city)}&url=${encodeURIComponent(pageUrl)}&via=mohrleisure`} target="_blank" rel="noopener">
							<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
							Post on X
						</a>
						<a class="share-btn" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener">
							<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
							Facebook
						</a>
					</div>
				</div>
			</article>

			{related.length > 0 && (
				<div class="related">
					<h2>More in {city}</h2>
					<div class="related-grid">
						{related.map((r) => (
							<a class="related-card" href={`/reviews/${r.id}/`}>
								<img src={r.data.photo} alt={r.data.photoAlt ?? r.data.venue} />
								<h3>{r.data.title}</h3>
								<p>{r.data.cuisine}</p>
							</a>
						))}
					</div>
				</div>
			)}
		</main>
		<Footer />
		<div class="lightbox" id="lightbox">
			<button class="lightbox-close" id="lightbox-close" aria-label="Close">&times;</button>
			<img id="lightbox-img" src="" alt="" />
		</div>

		<script>
			const lightbox = document.getElementById('lightbox') as HTMLElement;
			const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
			document.querySelectorAll<HTMLButtonElement>('.gallery-thumb').forEach(btn => {
				btn.addEventListener('click', () => {
					lightboxImg.src = btn.dataset.src ?? '';
					lightbox.classList.add('open');
				});
			});
			const closeLightbox = () => lightbox.classList.remove('open');
			document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
			lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
			document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

			const btn = document.getElementById('copy-link');
			if (btn) {
				btn.addEventListener('click', () => {
					navigator.clipboard.writeText(window.location.href).then(() => {
						btn.textContent = '✓ Copied!';
						setTimeout(() => { btn.textContent = 'Copy link'; }, 2000);
					});
				});
			}
		</script>
	</body>
</html>
