---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'reviews'>['data'] & {
	related?: CollectionEntry<'reviews'>[];
};

const { title, venue, city, neighborhood, cuisine, pubDate, photo, photoAlt, standoutDishes = [], related = [] } = Astro.props;

const description = standoutDishes.length > 0
	? `${cuisine} in ${neighborhood ? neighborhood + ', ' : ''}${city} — ${standoutDishes.slice(0, 2).join(', ')} and more. A review by Skyler & Kristen Mohr.`
	: `${cuisine} restaurant in ${neighborhood ? neighborhood + ', ' : ''}${city}. A review by Skyler & Kristen Mohr.`;

const pageTitle = `${title} | Mohr Leisure`;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Review',
	author: {
		'@type': 'Person',
		name: 'Skyler & Kristen Mohr',
		url: 'https://mohrleisure.com/about/',
	},
	datePublished: pubDate.toISOString().split('T')[0],
	itemReviewed: {
		'@type': 'Restaurant',
		name: venue,
		servesCuisine: cuisine,
		address: {
			'@type': 'PostalAddress',
			addressLocality: city,
			...(neighborhood ? { addressRegion: neighborhood } : {}),
		},
	},
	publisher: {
		'@type': 'Organization',
		name: 'Mohr Leisure',
		url: 'https://mohrleisure.com',
	},
};
---

<html lang="en">
	<head>
		<BaseHead
			title={pageTitle}
			description={description}
			image={photo}
			type="article"
			pubDate={pubDate}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				width: 100%;
				max-height: 500px;
				object-fit: cover;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.meta {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.dishes {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
				justify-content: center;
				margin-top: 0.75em;
			}
			.dish-tag {
				background: var(--accent);
				color: white;
				border-radius: 999px;
				padding: 0.2em 0.75em;
				font-size: 0.8em;
			}
			.breadcrumb {
				font-size: 0.8em;
				color: rgb(var(--gray));
				padding: 0.75em 1em;
				max-width: 720px;
				margin: 0 auto;
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.related {
				max-width: 720px;
				margin: 3em auto 0;
				padding: 2em 1em;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.related h2 {
				font-size: 1.2em;
				margin: 0 0 1.2em;
			}
			.related-grid {
				display: flex;
				gap: 1.5em;
				flex-wrap: wrap;
			}
			.related-card {
				flex: 1;
				min-width: 160px;
				text-decoration: none;
				color: inherit;
			}
			.related-card img {
				width: 100%;
				aspect-ratio: 3/2;
				object-fit: cover;
				border-radius: 8px;
				margin-bottom: 0.4em;
				transition: box-shadow 0.2s;
			}
			.related-card:hover img {
				box-shadow: var(--box-shadow);
			}
			.related-card h3 {
				font-size: 0.95em;
				margin: 0 0 0.2em;
				line-height: 1.3;
			}
			.related-card p {
				font-size: 0.78em;
				color: rgb(var(--gray));
				margin: 0;
			}
			.related-card:hover h3 {
				color: var(--accent);
			}
		</style>
	</head>

	<body>
		<Header />
		<nav class="breadcrumb" aria-label="Breadcrumb">
			<a href="/reviews/">Reviews</a>
			{' › '}
			<a href={`/reviews/?city=${encodeURIComponent(city)}`}>{city}</a>
			{' › '}
			<span>{venue}</span>
		</nav>
		<main>
			<article>
				<div class="hero-image">
					{photo && <img src={photo} alt={photoAlt ?? venue} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="meta">
							<FormattedDate date={pubDate} />
							{' · '}
							{cuisine}
							{' · '}
							{neighborhood ? `${neighborhood}, ` : ''}{city}
						</div>
						<h1>{title}</h1>
						{standoutDishes.length > 0 && (
							<div class="dishes">
								{standoutDishes.map((dish) => (
									<span class="dish-tag">{dish}</span>
								))}
							</div>
						)}
						<hr />
					</div>
					<slot />
				</div>
			</article>

			{related.length > 0 && (
				<div class="related">
					<h2>More in {city}</h2>
					<div class="related-grid">
						{related.map((r) => (
							<a class="related-card" href={`/reviews/${r.id}/`}>
								<img src={r.data.photo} alt={r.data.photoAlt ?? r.data.venue} />
								<h3>{r.data.title}</h3>
								<p>{r.data.cuisine}</p>
							</a>
						))}
					</div>
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
